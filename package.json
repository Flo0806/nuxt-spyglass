{
  "name": "nuxt-spyglass",
  "version": "1.0.0-alpha.3",
  "description": "Captures browser and server logs in one place and exposes them to AI tools via MCP.",
  "repository": "Flo0806/nuxt-spyglass",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "bin": {
    "nuxt-spyglass": "./dist/cli.mjs",
    "nuxt-spyglass-mcp": "./dist/mcp.mjs"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:docs": "nuxt dev docs -p 3005",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@jano-editor/ui": "1.0.0-alpha.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nuxt/kit": "^4.4.6",
    "consola": "^3.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.6",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.0",
    "nuxt": "^4.4.6",
    "typescript": "~6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  }
}
